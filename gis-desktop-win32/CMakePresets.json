{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 20, "patch": 0 },
  "configurePresets": [
    {
      "name": "win-vs2022",
      "displayName": "Windows VS2022 (inherits repo default: bundled DLL + ui_engine DLL)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/../build"
    },
    {
      "name": "release-static",
      "displayName": "正式版式：捆绑库与 ui_engine 全静态（链接较慢，输出目录 DLL 更少）",
      "inherits": "win-vs2022",
      "cacheVariables": {
        "AGIS_BUNDLED_LIBS_SHARED": "OFF",
        "AGIS_UI_ENGINE_SHARED": "OFF",
        "AGIS_MAP_ENGINE_SHARED": "OFF",
        "AGIS_COMMON_APP_SHARED": "OFF"
      }
    },
    {
      "name": "win-ninja",
      "displayName": "Windows Ninja（单配置，增量编译通常快于 VS 多工程；需安装 ninja）",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release-static-release",
      "configurePreset": "release-static",
      "configuration": "Release"
    },
    {
      "name": "win-vs2022-release",
      "configurePreset": "win-vs2022",
      "configuration": "Release"
    },
    {
      "name": "win-ninja-release",
      "configurePreset": "win-ninja"
    }
  ]
}
